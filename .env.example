VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_KHAN_PAYMENT_WALLET=
# The public Solana RPC is rate-limited and often rejects browser-origin
# requests. Set this to a dedicated provider (Helius, QuickNode, Alchemy,
# Triton, ...) for reliable holder counts, mint-authority checks, and
# real on-chain token-age lookups.
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional, free block-explorer API keys for accurate EVM token age
# (contract deployment timestamp) and upgradeable-contract detection.
# Get a free key at etherscan.io / bscscan.com / basescan.org /
# polygonscan.com. Each chain works independently - leave any blank to
# keep that chain's age reported as "Unknown" instead of guessed.
VITE_ETHERSCAN_API_KEY=
VITE_BSCSCAN_API_KEY=
VITE_BASESCAN_API_KEY=
VITE_POLYGONSCAN_API_KEY=

# Card payments (Stripe) - set on the frontend build (VITE_ vars) and as
# Netlify Function env vars (server-side, never exposed to the browser).
#
# Card payments are OFF unless VITE_STRIPE_ENABLED is exactly "true" AND a
# publishable key is present (see src/stripeCheckout.js isCardPaymentEnabled).
# Until then the UI shows only Wallet + Manual Crypto — no card buttons, no
# "not configured" notices. To turn Stripe on later: add the keys below, create
# the Products/Prices, point the webhook, and set VITE_STRIPE_ENABLED=true.
VITE_STRIPE_ENABLED=false
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_SUPPORTER_PRICE_ID=

# Optional email notifications for Support tickets, project Reports, and
# account emails (verification, password reset). Server-side only - read by
# netlify/functions/_email.mjs and auth-forgot-password.mjs via process.env,
# never a VITE_ var, so it is never bundled into the browser build. Reports/
# tickets/account emails keep working with no email sent if left blank.
RESEND_API_KEY=
SUPPORT_FROM_EMAIL=
KHAN_ADMIN_NOTIFY_EMAIL=

# KHAN Holder Analytics (admin module) - server-side only, used by the
# netlify/functions/khan-holders-* indexer functions, never shipped to the
# browser. Optional: get a free key at helius.dev for faster/more reliable
# indexing (enhanced RPC, higher rate limits). Without it, the indexer falls
# back to plain Solana RPC (SOLANA_RPC_URL, or the public endpoint) - slower
# but fully functional, and works unmodified on Pump.fun today and on
# Raydium after KHAN graduates.
HELIUS_API_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── KHAN Growth OS (private admin console at /console) ────────────────────────
# The Growth OS runs WITHOUT any of these. The event log, funnel, cohort
# retention, YouTube/TikTok attribution and content-demand ranking are all
# deterministic and need no AI. Only the analyst layer requires a key.
#
# ANTHROPIC_API_KEY: server-side only, never a VITE_ var, so it is never bundled
# into the browser. Without it the console shows every metric as normal and
# reports the analyst layer as switched off.
ANTHROPIC_API_KEY=

# Hard monthly ceiling on AI spend, in USD. Enforced in
# netlify/functions/_aiBudget.mjs BEFORE every call, and the ledger fails
# CLOSED - if it cannot be read, no spend is authorised. Default 10 if unset.
# The team runs weekly on Haiku 4.5 ($1/$5 per 1M tokens), so realistic spend is
# a few dollars a month; the cap exists to bound a bug, not normal use.
KHAN_AI_MONTHLY_BUDGET_USD=10

# Authentication (email/password accounts)
# AUTH_SECRET: random secret used to sign JWT tokens - generate with: openssl rand -hex 32
# Keep this secret and never commit it. Changing it invalidates all existing sessions.
AUTH_SECRET=
